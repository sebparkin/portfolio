{
  "expo": {
    "name": "portfolio",
    "slug": "portfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "portfolio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      ["expo-font",
        {
          "fonts": [
            "./assets/fonts/Prata-Regular.ttf",
            "./assets/fonts/Lora-Regular.ttf",
            "./assets/fonts/PTSerif-Regular.ttf",
            "./assets/fonts/PTSerif-Bold.ttf",
            "./assets/fonts/PTSerif-Italic.ttf",
            {
              "fontFamily": "Lora",
              "fontDefinitions": [
                {
                  "path": "./assets/fonts/Lora-Regular.ttf"
                }
              ]
            },
            {
              "fontFamily": "PTSerif",
              "fontDefinitions": [
                {
                  "path": "./assets/fonts/PTSerif-Regular.ttf"
                },
                {
                  "path": "./assets/fonts/PTSerif-Bold.ttf",

                  "weight": 700
                },
                {
                  "path": "./assets/fonts/PTSerif-Italic.ttf",
                  "style": "italic"
                }
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
